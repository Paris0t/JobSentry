# Required: Claude API key for AI job matching
JOBSENTRY_ANTHROPIC_API_KEY=sk-ant-...

# Optional: Job board credentials (used for cookie-based auth)
# JOBSENTRY_CLEARANCEJOBS_PASSWORD=
# JOBSENTRY_LINKEDIN_PASSWORD=

# Optional: Override default paths
# JOBSENTRY_DATA_DIR=~/.local/share/jobsentry
# JOBSENTRY_DB_PATH=~/.local/share/jobsentry/jobsentry.db

# Optional: AI model overrides
# JOBSENTRY_MATCH_MODEL=claude-sonnet-4-20250514
# JOBSENTRY_MATCH_THRESHOLD=0.65
# JOBSENTRY_DAILY_MATCH_LIMIT=10    # max jobs to AI-score per run (saves tokens)

# Optional: Browser settings
# JOBSENTRY_HEADLESS=true

# Telegram notifications (get from @BotFather)
# JOBSENTRY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# JOBSENTRY_TELEGRAM_CHAT_ID=123456789

# Email notifications (SMTP — Gmail app passwords work well)
# JOBSENTRY_SMTP_USERNAME=you@gmail.com
# JOBSENTRY_SMTP_PASSWORD=your-app-password
# JOBSENTRY_SMTP_HOST=smtp.gmail.com
# JOBSENTRY_SMTP_PORT=587
# JOBSENTRY_NOTIFY_EMAILS=you@gmail.com,other@work.com
